# Copy to /etc/sameway-admin.env on the VPS (systemd reads it from there).

SUPABASE_URL=https://gipmcjmhqvtfcsssaotn.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...        # service role — NEVER in any client

# Direct Postgres connection string, needed only for the /data table
# admin (admin/data-admin.js). Different from the two values above —
# find it in Supabase Dashboard -> Project Settings -> Database ->
# Connection string. Without this set, /data logs a warning and
# doesn't mount; the rest of the panel works normally either way.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

ADMIN_PASSWORD=change-me-long-random
SESSION_SECRET=change-me-different-long-random
PORT=8080
# 127.0.0.1 = reachable only via SSH tunnel (secure default, no TLS needed)
# 0.0.0.0   = public on PORT — only with a strong password; add TLS when a domain exists
HOST=127.0.0.1
